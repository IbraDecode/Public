    {
      "name": "Payment",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchant_id}}\",\n  \"amount\": 15000,\n  \"channel\": \"QRIS\",\n  \"source\": \"DYNAMIC_QRIS\",\n  \"feeBearer\": \"MERCHANT\",\n  \"customerName\": \"Budi\",\n  \"customerEmail\": \"budi@email.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v2/payments",
              "host": ["{{base_url}}"],
              "path": ["v2", "payments"]
            }
          }
        },
        {
