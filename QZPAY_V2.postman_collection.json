  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const crypto = require('crypto-js');",
          "",
          "const qzpayKey = pm.environment.get('qzpay_key');",
          "const qzpaySecret = pm.environment.get('qzpay_secret');",
          "",
          "if (!qzpayKey || !qzpaySecret) {",
          "  console.log('⚠️  Set qzpay_key dan qzpay_secret di environment');",
          "  return;",
          "}",
          "",
          "const method = pm.request.method;",
          "let url = pm.request.url.toString();",
          "",
          "// Parse URL — ambil path aja (tanpa base_url)",
          "const baseUrl = pm.environment.get('base_url') || 'https://api.qzpayment.com/v2';",
          "let path = url.replace(baseUrl, '');",
          "// Hapus query string dari path untuk signature",
          "const pathOnly = path.split('?')[0];",
          "",
          "// Dapatkan body",
          "let bodyStr = '';",
          "const body = pm.request.body;",
          "if (body && body.raw) {",
          "  try {",
          "    const parsed = JSON.parse(body.raw);",
          "    // Sort keys untuk canonical JSON",
          "    const sorted = Object.keys(parsed).sort().reduce((obj, key) => {",
          "      obj[key] = parsed[key];",
          "      return obj;",
          "    }, {});",
          "    bodyStr = JSON.stringify(sorted);",
          "  } catch(e) {",
          "    bodyStr = body.raw;",
          "  }",
          "}",
          "",
          "const bodyHash = crypto.SHA256(bodyStr).toString(crypto.enc.Hex).toLowerCase();",
          "const timestamp = new Date().toISOString().replace(/\\.\\d{3}/, '');",
          "const stringToSign = method + ':' + pathOnly + ':' + bodyHash + ':' + timestamp;",
          "const signature = crypto.HmacSHA256(stringToSign, qzpaySecret).toString(crypto.enc.Hex);",
          "",
          "pm.request.headers.upsert({ key: 'X-QZPAY-KEY', value: qzpayKey });",
          "pm.request.headers.upsert({ key: 'X-QZPAY-TIMESTAMP', value: timestamp });",
          "pm.request.headers.upsert({ key: 'X-QZPAY-SIGNATURE', value: signature });",
          "",
          "// Auto-add Content-Type untuk POST/PUT yang punya body",
          "if ((method === 'POST' || method === 'PUT') && body && body.raw) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
